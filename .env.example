# Copy this file to .env for local "vercel dev" testing.
# Never commit the real .env file.
#
# On Vercel: Project Settings -> Environment Variables, add the same
# values there. They stay server-side and are never sent to the browser.

ADMIN_USERNAME=marjo
ADMIN_PASSWORD=change-this-password
# Any long random string, e.g. generate with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# Needed for the Kirjat order form and the Yhteystiedot inquiry form
# (api/submit-form.js) to deliver submissions by email via https://resend.com.
# Sign up, verify a sending domain (or use their onboarding@resend.dev for testing),
# and create an API key.
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL=marjoseki@hotmail.com
FROM_EMAIL=onboarding@resend.dev
